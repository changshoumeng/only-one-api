    "markdown-it": "14.1.0",
    "@lucide/vue": "1.16.0",
    "mitt": "3.0.1",
    "nprogress": "0.2.0",
    "normalize.css": "8.0.1",
    "pinia": "2.0.33",
    "vue": "3.4.21",
    "vue-router": "4.1.6"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/compiler-sfc": "3.4.21",
    "@vue/test-utils": "2.4.10",
    "eslint": "8.57.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.4.0",
    "happy-dom": "20.9.0",
    "prettier": "3.3.0",
